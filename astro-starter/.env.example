# Hatch — Astro starter env
# Copy to .env and fill in your values. Never commit .env to git.

# WordPress REST API
WP_API_URL=https://cms.example.com/wp-json/wp/v2
WP_API_USER=editor
WP_API_PASS="abcd efgh ijkl mnop qrst uvwx"

# Hatch revalidation (must match the secret in WP Admin → Tools → Hatch)
HATCH_WEBHOOK_SECRET=replace-with-secret-from-wp-admin

# Public site URL (used for canonical URLs, sitemap, og:url)
PUBLIC_SITE_URL=http://localhost:4321

# Optional — Cloudflare Turnstile (for @hatch/shield form/comment protection)
# PUBLIC_TURNSTILE_SITE_KEY=0xAAAAAAA
# TURNSTILE_SECRET_KEY=0xBBBBBBB

# Optional — Disqus (for @hatch/comments)
# PUBLIC_DISQUS_SHORTNAME=your-shortname
