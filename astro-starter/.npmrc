# Tell npm to ignore peer-dependency conflicts.
#
# Why this exists: @astrojs/tailwind@6.0.2 declares a peer dep on Astro 3/4/5,
# but Hatch's starter is on Astro 6. The runtime works fine — only the install-
# time peer-dep check fails. This flag bypasses that check.
#
# v0.10 will replace @astrojs/tailwind with @tailwindcss/vite (the Astro 6
# native path), at which point this .npmrc can be removed.
legacy-peer-deps=true
