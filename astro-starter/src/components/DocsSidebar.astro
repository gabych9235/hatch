---
/**
 * DocsSidebar — left-rail category navigation tuned for the docs theme.
 *
 * Renders WP categories as a sticky vertical nav grouped under a "Topics"
 * heading. Each category links to its archive; current-page category is
 * highlighted. Post count shown as a muted chip.
 *
 * Used only when features.theme === 'docs'. Rendered alongside the article
 * body in blog/[slug].astro and blog/index.astro.
 */
import { getCategories } from '../lib/hatch';

interface Props {
  /** Slug of the category currently being viewed (if any) — drives the active highlight. */
  activeCategorySlug?: string | null;
  /** Show the sidebar's own "Browse" heading. Default true. */
  showHeading?: boolean;
}

const { activeCategorySlug = null, showHeading = true } = Astro.props;

// Tolerate any shape — we only need slug / name / count from each item.
const rawCats: any[] = await getCategories().catch(() => []);
const categories = (rawCats || [])
  .filter((c: any) => (c?.count ?? 0) > 0)
  .sort((a: any, b: any) => (b?.count ?? 0) - (a?.count ?? 0));
---

<aside class="hatch-docs-sidebar sticky top-14 self-start" style="max-height: calc(100vh - 56px); overflow-y: auto; padding: 24px 16px 24px 0;">
  {showHeading && (
    <div class="text-[11px] font-semibold uppercase tracking-widest text-hatch-fg-subtle mb-3 px-2">Browse</div>
  )}

  <nav aria-label="Topics" class="flex flex-col gap-0.5">
    <a
      href="/blog"
      class:list={[
        'flex items-center justify-between gap-2 px-3 py-1.5 rounded-md text-[13px] transition-colors',
        !activeCategorySlug
          ? 'bg-hatch-bg-3 text-hatch-fg font-medium'
          : 'text-hatch-fg-muted hover:text-hatch-fg hover:bg-hatch-bg-2',
      ]}
    >
      <span>All posts</span>
    </a>

    {categories.length > 0 && (
      <>
        <div class="text-[10px] font-semibold uppercase tracking-widest text-hatch-fg-subtle mt-5 mb-2 px-3">Categories</div>
        {categories.map((cat) => (
          <a
            href={`/blog/category/${cat.slug}`}
            class:list={[
              'flex items-center justify-between gap-2 px-3 py-1.5 rounded-md text-[13px] transition-colors',
              activeCategorySlug === cat.slug
                ? 'bg-hatch-bg-3 text-hatch-fg font-medium border-l-2 border-hatch-primary -ml-px pl-[10px]'
                : 'text-hatch-fg-muted hover:text-hatch-fg hover:bg-hatch-bg-2',
            ]}
          >
            <span class="truncate">{cat.name}</span>
            <span class="text-[11px] text-hatch-fg-subtle tabular-nums shrink-0">{cat.count}</span>
          </a>
        ))}
      </>
    )}

    {categories.length === 0 && (
      <p class="text-[12px] text-hatch-fg-subtle px-3 py-2">No categories yet. Publish posts in categories on WordPress to populate this nav.</p>
    )}
  </nav>
</aside>
