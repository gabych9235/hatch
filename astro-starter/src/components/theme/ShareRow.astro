---
/**
 * Shared share row — used by every per-theme Single layout. Renders only
 * the networks that are toggled ON in admin (Design > Sharing > Networks).
 * Style is theme-agnostic; placement / wrapper styling is up to the parent.
 */
import type { HatchFeatures } from '../../lib/features';

interface Props {
  features: HatchFeatures;
  title: string;
  url: string;
}
const { features, title, url } = Astro.props;
const s = features.aesthetic.share;
const shareText = encodeURIComponent(`${title} — ${url}`);
const shareUrl  = encodeURIComponent(url);

const NETS = [
  { key: 'x',        label: 'X',         href: `https://twitter.com/intent/tweet?text=${shareText}`,                                  icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { key: 'linkedin', label: 'LinkedIn',  href: `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`,                     icon: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z' },
  { key: 'whatsapp', label: 'WhatsApp',  href: `https://wa.me/?text=${shareText}`,                                                    icon: 'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z' },
  { key: 'facebook', label: 'Facebook',  href: `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`,                            icon: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z' },
  { key: 'reddit',   label: 'Reddit',    href: `https://www.reddit.com/submit?url=${shareUrl}&title=${shareText}`,                    icon: 'M12 8c2.21 0 4 1.79 4 4s-1.79 4-4 4-4-1.79-4-4 1.79-4 4-4z' },
  { key: 'email',    label: 'Email',     href: `mailto:?subject=${shareText}&body=${shareUrl}`,                                       icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zM22 6l-10 7L2 6' },
  { key: 'copy',     label: 'Copy link', href: url, copy: true, icon: 'M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71' },
] as const;
---
<div class="flex flex-wrap items-center gap-2">
  <span class="text-[12.5px] text-hatch-fg-subtle mr-1">Share</span>
  {NETS.filter((n) => (s as any)[n.key]).map((n) => (
    n.copy ? (
      <button
        type="button"
        data-url={url}
        aria-label={n.label}
        title={n.label}
        class="hatch-share-copy inline-flex items-center justify-center w-9 h-9 rounded-md border border-hatch-border text-hatch-fg-muted hover:text-hatch-fg hover:border-hatch-fg hover:bg-hatch-bg-2 transition-colors"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true"><path d={n.icon} /></svg>
      </button>
    ) : (
      <a
        href={n.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={n.label}
        title={n.label}
        class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-hatch-border text-hatch-fg-muted hover:text-hatch-fg hover:border-hatch-fg hover:bg-hatch-bg-2 transition-colors"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true"><path d={n.icon} /></svg>
      </a>
    )
  ))}
</div>

<script is:inline>
  document.querySelectorAll('.hatch-share-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-url') || '';
      navigator.clipboard?.writeText(url);
      btn.setAttribute('title', 'Copied!');
      setTimeout(() => btn.setAttribute('title', 'Copy link'), 1500);
    });
  });
</script>
