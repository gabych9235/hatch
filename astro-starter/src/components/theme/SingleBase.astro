---
/**
 * SingleBase — default "blog" theme single-post layout. All other per-theme
 * Single layouts can compose around this or override entirely.
 *
 * Token discipline: NEVER hardcodes fonts or colors — every visual flows
 * from CSS vars set by Global Tokens in the WP admin.
 *
 * Receives the FULLY-PREPARED data from the page route (blog/[slug].astro).
 * This component does no fetching itself.
 */
import HatchImage from '../HatchImage.astro';
import ShareRow from './ShareRow.astro';

interface Props {
  post: any;
  features: any;
  toc: Array<{ level: 2 | 3; text: string; id: string }>;
  related: any[];
  adjacent: { prev: any; next: any };
  dateLabel: string;
  updatedLabel: string;
  canonical: string;
  bodyHtml: string;        // post.content already rewritten through media proxy
  /** Visibility + style flags resolved by the parent page. */
  flags: {
    showBreadcrumb: boolean;
    showReadingTime: boolean;
    showUpdated: boolean;
    showTOC: boolean;
    showShare: boolean;
    showAuthorBio: boolean;
    showRelated: boolean;
    showPrevNext: boolean;
    showComments: boolean;
    showHeroImage: boolean;
    heroCompact: boolean;
    sidebarSide: 'left' | 'right' | 'none';
    breadcrumbSep: string;
    avatarShape: string;
    readingTimeText: (m: number) => string;
  };
}
const { post, features, toc, related, adjacent, dateLabel, updatedLabel, canonical, bodyHtml, flags } = Astro.props;
// v0.50.31 — Sidebar position is the DOMINANT control. Dropped the
// `flags.showTOC` gate so the Sidebar chip in Design tab is authoritative:
//   'none'  → no sidebar column, ever
//   'left'  → sidebar on left  iff there's content to put in it
//   'right' → sidebar on right iff there's content to put in it
// "Content" today = TOC entries; future-proofed for related/categories/etc.
const showSidebar = flags.sidebarSide !== 'none' && toc.length > 0;
---
<article class="mx-auto px-5 sm:px-8 py-10 sm:py-14" style="max-width: var(--hatch-max-width, 1160px);">
  {flags.showBreadcrumb && (
    <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-[12.5px] text-hatch-fg-subtle mb-8 flex-wrap">
      <a href="/" class="hover:text-hatch-fg transition-colors">Home</a>
      <span class="text-hatch-fg-subtle">{flags.breadcrumbSep}</span>
      <a href="/blog" class="hover:text-hatch-fg transition-colors">Blog</a>
      {post.category && (
        <>
          <span class="text-hatch-fg-subtle">{flags.breadcrumbSep}</span>
          <a href={`/blog/category/${post.category.slug}`} class="hover:text-hatch-fg transition-colors">{post.category.name}</a>
        </>
      )}
      <span class="text-hatch-fg-subtle">{flags.breadcrumbSep}</span>
      <span class="text-hatch-fg truncate max-w-[260px] sm:max-w-none">{post.title}</span>
    </nav>
  )}

  <header class="max-w-3xl mb-10">
    {post.category && (
      <a href={`/blog/category/${post.category.slug}`} class="inline-block text-[11px] uppercase tracking-wider font-medium text-hatch-primary mb-4 hover:underline">{post.category.name}</a>
    )}
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight leading-[1.1]" style="font-family: var(--hatch-font-heading);">{post.title}</h1>
    <div class="mt-6 flex items-center flex-wrap gap-x-4 gap-y-2 text-[13.5px] text-hatch-fg-muted">
      {post.author && (
        <a href={`/blog/author/${post.author.slug}`} class="flex items-center gap-2 hover:text-hatch-fg transition-colors">
          {post.author.avatar && <img src={post.author.avatar} alt={post.author.name} width="24" height="24" class={`${flags.avatarShape} flex-shrink-0`} loading="lazy" />}
          <span>{post.author.name}</span>
        </a>
      )}
      <span class="text-hatch-fg-subtle">·</span>
      <time datetime={post.publishedAt}>{dateLabel}</time>
      {flags.showReadingTime && (
        <>
          <span class="text-hatch-fg-subtle">·</span>
          <span>{flags.readingTimeText(post.readMinutes)}</span>
        </>
      )}
    </div>
    {flags.showUpdated && updatedLabel && (
      <p class="mt-2 text-[12px] text-hatch-fg-subtle italic">Last updated {updatedLabel}</p>
    )}
  </header>

  {flags.showHeroImage && (
    <div class={`${flags.heroCompact ? 'aspect-[3/1]' : 'aspect-[2/1]'} rounded-xl overflow-hidden bg-hatch-bg-3 mb-12 max-w-5xl`}>
      <HatchImage src={post.featuredImage} alt={post.title} class="w-full h-full object-cover" width={1600} height={flags.heroCompact ? 533 : 800} />
    </div>
  )}

  <div class={`grid gap-x-10 gap-y-8 ${showSidebar ? `max-w-5xl ` + (flags.sidebarSide === 'left' ? 'lg:grid-cols-[240px_1fr]' : 'lg:grid-cols-[1fr_240px]') : 'grid-cols-1'}`}>
    <div class={`hatch-prose min-w-0 ${flags.sidebarSide === "left" ? "lg:order-2" : "lg:order-1"}`}>
      <div set:html={bodyHtml} />
    </div>

    {showSidebar && (
      <aside class={`hidden lg:block ${flags.sidebarSide === "left" ? "lg:order-1" : "lg:order-2"}`}>
        <div class="sticky top-20 max-h-[calc(100vh-7rem)] overflow-y-auto pr-2">
          <div class="text-[11px] font-semibold uppercase tracking-widest text-hatch-fg-subtle mb-3">{features.aesthetic.reading.toc_label}</div>
          <nav class="flex flex-col gap-1 text-[13px]" aria-label="Table of Contents">
            {toc.map((item) => (
              <a href={`#${item.id}`} class={`hover:text-hatch-primary transition-colors text-hatch-fg-muted ${item.level === 3 ? 'pl-3' : ''}`}>{item.text}</a>
            ))}
          </nav>
        </div>
      </aside>
    )}
  </div>

  {flags.showShare && (
    <div class="max-w-3xl mt-12 pt-8 border-t border-hatch-border">
      <ShareRow features={features} title={post.title} url={canonical} />
    </div>
  )}

  {flags.showAuthorBio && post.author?.description && (
    <div class="max-w-3xl mt-12 p-6 rounded-xl border border-hatch-border bg-hatch-bg-2 flex gap-4 items-start">
      {post.author.avatar && <img src={post.author.avatar} alt={post.author.name} width="48" height="48" class={`${flags.avatarShape} flex-shrink-0`} loading="lazy" />}
      <div class="min-w-0">
        <a href={`/blog/author/${post.author.slug}`} class="font-semibold text-hatch-fg hover:text-hatch-primary transition-colors">{post.author.name}</a>
        <p class="text-[14px] text-hatch-fg-muted mt-1 leading-relaxed">{post.author.description}</p>
      </div>
    </div>
  )}

  {flags.showPrevNext && (adjacent.prev || adjacent.next) && (
    <nav class="max-w-3xl mt-14 pt-10 border-t border-hatch-border grid grid-cols-1 sm:grid-cols-2 gap-3" aria-label="Post navigation">
      {adjacent.prev && (
        <a href={`/blog/${adjacent.prev.slug}`} class="group p-5 rounded-xl border border-hatch-border hover:border-hatch-fg transition-colors">
          <span class="text-[11px] uppercase tracking-wider text-hatch-fg-subtle">← Previous</span>
          <div class="mt-1 font-medium text-hatch-fg group-hover:text-hatch-primary transition-colors line-clamp-2">{adjacent.prev.title}</div>
        </a>
      )}
      {adjacent.next && (
        <a href={`/blog/${adjacent.next.slug}`} class="group p-5 rounded-xl border border-hatch-border hover:border-hatch-fg transition-colors sm:text-right">
          <span class="text-[11px] uppercase tracking-wider text-hatch-fg-subtle">Next →</span>
          <div class="mt-1 font-medium text-hatch-fg group-hover:text-hatch-primary transition-colors line-clamp-2">{adjacent.next.title}</div>
        </a>
      )}
    </nav>
  )}

  <slot name="related" />
  <slot name="comments" />
</article>
