{
    "name": "adityaarsharma/hatch",
    "description": "The Headless Engine for WordPress. One plugin — premium admin, frontend agent, 8 Gutenberg blocks, REST hardening.",
    "type": "wordpress-plugin",
    "license": "MIT",
    "homepage": "https://github.com/adityaarsharma/hatch",
    "authors": [
        {
            "name": "Aditya Sharma",
            "homepage": "https://adityaarsharma.com"
        }
    ],
    "support": {
        "issues": "https://github.com/adityaarsharma/hatch/issues",
        "source": "https://github.com/adityaarsharma/hatch"
    },
    "require": {
        "php": ">=7.4",
        "composer/installers": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "wp-phpunit/wp-phpunit": "^6.4",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "scripts": {
        "phpcs":     "phpcs --standard=phpcs.xml.dist",
        "phpcbf":    "phpcbf --standard=phpcs.xml.dist",
        "phpstan":   "phpstan analyse --memory-limit=512M",
        "test":      "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "qa":        ["@phpcs", "@phpstan", "@test"],
        "build-zip": [
            "@php -r \"if (is_dir('build')) { array_map('unlink', glob('build/*')); rmdir('build'); }\"",
            "@php -r \"mkdir('build', 0755, true); recurse_copy('wp-plugin', 'build/hatch'); function recurse_copy($src, $dst) { $dir = opendir($src); @mkdir($dst); while (false !== ($file = readdir($dir))) { if (($file != '.') && ($file != '..')) { if (is_dir($src.'/'.$file)) recurse_copy($src.'/'.$file, $dst.'/'.$file); else copy($src.'/'.$file, $dst.'/'.$file); } } closedir($dir); }\"",
            "cd build && zip -rq hatch.zip hatch"
        ]
    },
    "scripts-descriptions": {
        "phpcs":     "Run WordPress Coding Standards check on PHP files",
        "phpcbf":    "Auto-fix WPCS violations where possible",
        "phpstan":   "Static analysis (level 5) on PHP code",
        "test":      "Run the full PHPUnit suite",
        "test:unit": "Run only unit tests (skip integration)",
        "qa":        "Run lint + static analysis + tests (the full pre-PR check)"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "autoload-dev": {
        "psr-4": {
            "Hatch\\Tests\\": "tests/"
        }
    }
}
