{
  "name": "hatch-wp",
  "version": "0.1.3",
  "description": "Hatch — headless WordPress engine. Companion plugin + 8 headless-first Gutenberg blocks with Tailwind utility output.",
  "license": "MIT",
  "author": "Aditya Sharma <hi@adityaarsharma.com>",
  "homepage": "https://github.com/adityaarsharma/hatch",
  "repository": {
    "type": "git",
    "url": "https://github.com/adityaarsharma/hatch.git",
    "directory": "wp-plugin"
  },
  "private": true,
  "scripts": {
    "build": "wp-scripts build blocks-src/index.js --output-path=build",
    "build:interactive": "wp-scripts build blocks-src/interactive/index.js --output-path=build --output-filename=interactive.js",
    "build:tailwind": "tailwindcss -i ./blocks-src/styles/editor-tailwind.css -o ./build/editor-tailwind.css --minify",
    "build:admin": "wp-scripts build admin-react/src/index.jsx --output-path=build/admin",
    "watch:admin": "wp-scripts start admin-react/src/index.jsx --output-path=build/admin",
    "build:all": "npm run build && npm run build:interactive && npm run build:tailwind && npm run build:admin",
    "start": "wp-scripts start blocks-src/index.js --output-path=build",
    "watch:tailwind": "tailwindcss -i ./blocks-src/styles/editor-tailwind.css -o ./build/editor-tailwind.css --watch",
    "lint:js": "wp-scripts lint-js blocks-src/",
    "lint:css": "wp-scripts lint-style blocks-src/",
    "format": "wp-scripts format blocks-src/",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@wordpress/blocks": "^13.0.0",
    "@wordpress/block-editor": "^14.0.0",
    "@wordpress/components": "^28.0.0",
    "@wordpress/data": "^10.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/hooks": "^4.0.0",
    "@wordpress/i18n": "^5.0.0",
    "@wordpress/icons": "^10.0.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@wordpress/scripts": "^28.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
